    style: [centra, centra,centra, fechas,  centra, izq, centra,  soles, izq], height: 35


    when 2,3
    sheet.add_row [  vconta2,Formula.where(product_id:1,orden:ite.obac).select('nombre as dd').first.dd,ite.pac,
