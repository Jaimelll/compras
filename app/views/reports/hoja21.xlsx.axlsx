         style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu], height: 40
         sheet.column_widths 5, 10,10,10,40, nil,10,10,10,10,10, 30



       end




       @conta=0
       vcorpo=0
       vconta2=0
       vlineai=1
       vlineaf=1
       vexp =   "s/d"
      @items.where(id:@vpacn,tipo:merca.orden,modalidad:modal.orden).each do |ite|

        vdesc=ite.descripcion

        @vpact3=Formula.where(product_id:12,acti:3).select('orden')
       @vdetalle= Detail.where(actividad: Formula .where(product_id:12,cantidad:proce.orden).select('orden')).order('pfecha')
       @vdetalle= @vdetalle.where(actividad:@vpact3,item_id:ite.id)

       @vobsr=" "
