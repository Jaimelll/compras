
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3>Periodo:<%=   @lista.titleize %> </h3>
</head>
<% if @items.select {|f| f["acti"]== 5 and f["periodo"]==@vperiodo}.count>0 then %>




</h4>





<h4>EXPEDIENTES EN PROCESO DE COMPRAS:</h4>
<table >
    <tr>
        <br>
       <th>N°</th>
       <th>Exp</th>
       <th>Pac</th>
      <th>Obac</th>
      <th>Descripcion</th>
      <th>Estimado</th>

      <th colspan="3"></th>
    </tr>

    
    <%  @conta=0 %>

    <% @items.select {|f| f["acti"]== 5 and f["periodo"]==@vperiodo}.
    sort_by { |k| [k["obac"], k["pac"]] }.each do |variable| %>


    <% @var= variable["id"] %>
        <tr>
            <tbody>
              <br>

          <% @conta=@conta+1 %>

        <td colspan="1"><%= @conta.to_s+".-" %></td>
              <%@vexp= @vite.where(id:@var).
              select('expediente as dd').first.dd %>
            <% if @vexp.to_i>0 then %>

         <td colspan="1"><%= Formula.where(product_id:16,orden:@vexp.to_i).select('nombre as dd').first.dd %></td>
             <% else %>
        <td><%= " s/d"   %></td>
             <% end %>


        <td  colspan="1"><%= @vite.where(id:@var).
         select('pac as dd').first.dd %></td>

         <%@vobac= @vite.where(id:@var).
          select('obac as dd').first.dd%>


        <td  colspan="1"><%= Formula.where(product_id:1,orden:@vobac).select('nombre as dd').first.dd %></td>
        <%@vdesc= @vite.where(id:@var).
         select('descripcion as dd').first.dd%>

        <td  colspan="1"><h4><%= @vdesc.capitalize %></h4></td>

         <%@vval= @vite.where(id:@var).
          select('certificado as dd').first.dd%>

        <td  colspan="1"><%= number_with_delimiter(@vval.to_i, delimiter: ",") %></td>
      </tbody>
        </tr>


    </table>

      <% if @vdetalle.where("details.actividad=18 or details.actividad=20 or details.actividad=56").count>0 then %>
      <table width="800" border="1">

          <tr>

            <th>Fecha</th>
            <th>Actividad</th>
            <th>Observacion</th>


        <tbody>


          <% @vdetalle.where("details.actividad=18 or details.actividad=20 or details.actividad=56").
          each do |deta| %>


       <tr>




               <td c><%= deta.pfecha %></td>
               <td ><%=Formula.where(product_id:12,orden:deta.actividad).
                           select('descripcion as dd').first.dd.capitalize  %></td>
               <td colspan="3"><%= deta.obs.capitalize %></td>

       </tr>


       <% end %>






          <% end %>

        </tbody>

      </table>



    <% end %>


<% else %>
<br>
<br>
 <td> No hay procesos en esta etapa  </td>
 <br>
 <br>
<% end %>
