
    <Table border="1">
     <tr>
        <th>AVANCE</th>
        <th>S/EXP</th>
        <th>C/EXP</th>
        <th>DC</th>
        <th>DEM</th>
        <th>DPC</th>
        <th>FC</th>
        <th>EC</th>
        <th>TOTAL</th>
      </tr>
      <tr>
        <th>PAC</th>
        <th><%= @vnpac[1] %></th>
        <th><%= @vnpac[2] %></th>
        <th><%= @vnpac[3] %></th>
        <th><%= @vnpac[4] %></th>
        <th><%= @vnpac[5] %></th>
        <th><%= @vnpac[6] %></th>
        <th><%= @vnpac[7] %></th>
        <th><%= @vnpac[1].to_i+@vnpac[2].to_i+@vnpac[3].to_i+@vnpac[4].to_i+@vnpac[5].to_i+@vnpac[6].to_i+@vnpac[7].to_i%></th>
      </tr>
      <tr>
        <th>MONTO(SOLES)</th>
        <td><%= @vmpac[1].to_i %></td>
        <td><%= @vmpac[2].to_i %></td>
        <td><%= @vmpac[3].to_i %></td>
        <td><%= @vmpac[4].to_i %></td>
        <td><%= @vmpac[5].to_i %></td>
        <td><%= @vmpac[6].to_i %></td>
        <td><%= @vmpac[7].to_i %></td>
        <td><%= @vmpac[1].to_i+@vmpac[2].to_i+@vmpac[3].to_i+@vmpac[4].to_i+@vmpac[5].to_i+@vmpac[6].to_i+@vmpac[7].to_i%></td>
      </tr>

    </Table>
      <%Formula.where(product_id:10).order('orden').where('orden<5').each do |proce| %>
    <Table border="1">
 <tr>
   <th><%= proce.nombre%></th>
 </tr>
     <tr>
        <th>N</th>
        <th>PAC</th>
        <th>FECHA PAC</th>
        <th>OBAC</th>
        <th>DESCRIPCION</th>
        <th>FUENTE DE FINANCIAMIENTO</th>
        <th>MONTO</th>
        <th>SITUACION ACTUAL</th>
      </tr>
<%  case proce.orden %>
<%  when 1 %>
<%  @vpacn=@vpac1 %>
<%  when 2 %>
<%  @vpacn=@vpac2 %>
<%  when 3 %>
<%  @vpacn=@vpac3 %>
<%  when 4 %>
<%  @vpacn=@vpac4 %>
<%  end %>
<%  @conta=0 %>
  <%  @items.where(id:@vpacn).each do |ite| %>
   <tr>
       <% @conta=@conta+1 %>
 <td ><%= @conta %></td>
 <td><%= ite.pac%></td>

 <% if ite.mesconvoca then%>

 <td><%= ite.mesconvoca.strftime("%m - %Y")%></td>
 <% else%>
 <td></td>
 <% end%>

 <td><%=Formula.where(product_id:1,orden:ite.obac).select('nombre as dd').first.dd  %></td>
 <td><%= ite.descripcion%></td>

 <td><%= Formula.where(product_id:8,orden:ite.fuente).select('nombre as dd').first.dd %></td>
 <td><%= ite.certificado%></td>

 <%  @vpact3=Formula.where(product_id:12,acti:3).select('orden')%>

 <% @vdetalle= Detail.where(actividad: Formula .where(product_id:12,cantidad:proce.orden).select('orden')).order('pfecha')%>
 <% @vdetalle= @vdetalle.where(actividad:@vpact3,item_id:ite.id)%>

 <% if @vdetalle.count>0%>
<% @vdetalle.each do |deta|%>
<% @vobsr=deta.pfecha.strftime("%d/%m/%y").to_s+"-"+ deta.obs.capitalize%>
<% end %>
 <td><%= @vobsr%></td>


 <% end %>


  </tr>
  <% end %>
    </Table>
    <% end %>
