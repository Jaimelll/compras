
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3>Periodo:<%=   @lista.titleize %> </h3>
<h4><%= @titproc %></h4>
</head>
<% if @items.select {|f| f["acti"]== @numproc and f["periodo"]==@vperiodo}.count>0 then %>

<table >
    <tr>

       <th>N°</th>
       <th>Exp</th>
       <th>Pac</th>
       <th>Obac</th>
       <th>Lista</th>
       <th>Descripcion</th>
       <th>Estimado</th>


    </tr>


    <%  @conta=0 %>

    <% @items.select {|f| f["acti"]==@numproc and f["periodo"]==@vperiodo}.
    sort_by { |k| [k["obac"], k["pac"]] }.each do |variable| %>


    <% @var= variable["id"] %>
        <tr>
            <tbody>
              <br>

          <% @conta=@conta+1 %>

        <td VALIGN=top><%= @conta.to_s+".-" %></td>
              <%@vexp= @vite.where(id:@var).
              select('expediente as dd').first.dd %>
            <% if @vexp.to_i>0 then %>

         <td VALIGN=top><%= Formula.where(product_id:16,orden:@vexp.to_i).select('nombre as dd').first.dd %></td>
             <% else %>
        <td><%= " s/d"   %></td>
             <% end %>


        <td  VALIGN=top><%= @vite.where(id:@var).
         select('pac as dd').first.dd %></td>


         <%@vobac= @vite.where(id:@var).
          select('obac as dd').first.dd%>


        <td  VALIGN=top><%= Formula.where(product_id:1,orden:@vobac).select('nombre as dd').first.dd %></td>


         <%@vlist= @vite.where(id:@var).
          select('lista as dd').first.dd%>
        <td  VALIGN=top><%= Formula.where(product_id:3,orden:@vlist).select('nombre as dd').first.dd %></td>


        <%@vdesc= @vite.where(id:@var).
         select('descripcion as dd').first.dd%>



        <td  VALIGN=top ><h4><%= @vdesc.capitalize %></h4>





      <% if @vdetalle.where(item_id:@var).where("details.actividad=18 or
        details.actividad=20 or details.actividad=56 or
        details.actividad=13 or details.actividad=58 or

        details.actividad=300").count>0 then %>
      <table width="800" border="1">

          <tr>

            <th>Fecha</th>
            <th>Actividad</th>
            <th>Observacion</th>
         </tr>

        <tbody>


          <% @vdetalle.where(item_id:@var).where("details.actividad=18 or
               details.actividad=20 or details.actividad=56 or
                details.actividad=13 or details.actividad=58 or

                details.actividad=300").
          each do |deta| %>


       <tr>




               <td ALIGN=center><%= deta.pfecha.strftime("%d-%m-%Y") %></td>
               <td ALIGN=center><%=Formula.where(product_id:12,orden:deta.actividad).
                           select('descripcion as dd').first.dd.capitalize  %></td>
               <td ALIGN=center><%= deta.obs.capitalize %></td>

       </tr>


       <% end %>

     </tbody>

      </table>


          <% end %>





    </td>
    <%@vval= @vite.where(id:@var).
     select('certificado as dd').first.dd%>

   <td  VALIGN=top ALIGN=right><%= number_with_delimiter(@vval.to_i, delimiter: ",") %></td>
    </tr>


    <% end %>
    <br>
  </tbody>
  </table>

<% else %>
<br>
<br>
 <td> No hay procesos en esta etapa  </td>
 <br>
 <br>
<% end %>
</html>
