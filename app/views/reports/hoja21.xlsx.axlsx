      @vdetalle.each do |deta|

      if deta.obs then
      @vobsr=deta.obs.capitalize
       end
     end
    end



    if ite.exped and ite.exped>0 then

      exp =Formula.where(product_id:16, orden:ite.exped).
        select('nombre as dd').first.dd

      else
        exp =   "s/d"
      end



if exp =="s/d" or exp!=vexp then
   @conta=@conta+1
   vexp=exp
   vconta2=@conta



   vcorpo=0
else
  if vcorpo==0 then
      vlineai = sheet.rows.last.index+1
      vdesc=Formula.where(product_id:16,orden:ite.exped).select('nombre as dd').first.dd
  end
     vcorpo=vcorpo+1
     vconta2=nil
     vdesc=nil
     vlineaf = sheet.rows.last.index+2
     sheet.merge_cells "A#{vlineai}:A#{vlineaf}"
     case proce.orden
        when 1
             sheet.merge_cells "F#{vlineai}:F#{vlineaf}"
