
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3><%=   @lista.titleize %> </h3>
</head>

  <% if @items.where(tipo:1).count>0 then %>

<table>

  <thead>
<h4> ENCARGO-NACIONALES:  </h4>
    <tr>
      <th>N°</th>
      <th>Pac</th>

      <th>Obac</th>

      <th>Descripcion</th>

      <th>Estimado</th>


      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>

    <%  @conta=0 %>

    <% @items.where(tipo:1).each do |item| %>

        <tr>
          <% @conta=@conta+1 %>
        <td><%= @conta.to_s+".-" %></td>
        <td><%= item.pac.to_i %></td>

        <td><%= Formula.where(product_id:1,orden:item.obac).select('nombre as dd').first.dd %></td>

        <td><%= item.descripcion.underscore.capitalize %></td>

        <td ALIGN=right><%= number_with_delimiter(item.certificado.to_i, delimiter: ",") %></td>


      </td>
      </tr>

    <% end %>

  </tbody>

</table>
<h3>Procesos = <%=   @conta %></h3>
<h3>Total(Soles) = <%=   number_with_delimiter(@items.where(tipo:1).sum(:certificado).to_i, delimiter: ",") %></h3>

<br>
<% else %>
<br>
<br>
 <td> No hay procesos Encargo-Nacionales en esta Lista  </td>
 <br>
 <br>
<% end %>
  <% if @items.where(tipo:2).count>0 then %>

