
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
</head>

<h2>Engargo - <%=   @lista %></h2>

<table>
  <thead>

    <tr>
      <th>Pac</th>

      <th>Obac</th>

      <th>Descripcion</th>

      <th>Estimado</th>


      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @items.each do |item| %>
        <tr>
        <td><%= item.pac %></td>

        <td><%= item.obac %></td>

        <td><%= item.descripcion.underscore.capitalize %></td>

        <td><%= number_with_delimiter(item.certificado.to_i, delimiter: ",") %></td>


      </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
