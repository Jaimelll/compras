                         Formula.where(product_id:4,orden:modal.orden).select('nombre as dd').first.dd%> </h3>




<table>

  <tr  style="font-size:90%;">

    <th>N°</th>
    <th>Exped</th>
    <th>PAC</th>
    <th>OBAC</th>
    <th>Fuente</th>

