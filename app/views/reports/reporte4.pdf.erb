
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3><%=   @tit1 %> </h3>
</head>

  <% if @activities.length>0 then %>
<table >



    <tr style="font-size:90%;" >
      <th >N°</th>
      <%  if @vopc==4 then %>
       <th >Ingreso DPC</th>
       <th ></th>
       <%  @idpc=34%>
      <%  else%>
      <th >Fecha Conv</th>
      <th >Fecha BP</th>
       <%  @idpc=19%>
     <%  end%>

       <th >Nomenclatura</th>
       <th >OBAC</th>
       <th colspan="3">Descripcion</th>
       <th >Moneda</th>
        <th >Referencial</th>

      <%  if @vopc==2 or  @vopc==3 then %>
       <th >Adjudicado</th>

       <%  end%>


    </tr>


  <tbody>
    <%  @conta=0 %>
    <% @activities.each do |activity| %>

        <tr style="font-size:80%;"   >

          <% @conta=@conta+1 %>




        <td ><%= @conta.to_s+".-" %></td>



  <% if Activity.where(actividad:@idpc,phase_id:activity.id.to_s)
    .count>0 then %>

<%  @vaconv=Activity.where(actividad:@idpc,phase_id:activity.id.to_s)
             .select('pfecha as dd').first.dd%>
             <td   ><%=  @vaconv.strftime("%d-%m") %></td>
             <%  else %>
             <td  ></td>
              <%  end %>



          <% if Activity.where(actividad:20,phase_id:activity.id.to_s)
                .count>0 then %>

              <%  @vabp=Activity.where(actividad:20,phase_id:activity.id.to_s)
                         .select('pfecha as dd').first.dd%>
                         <td   ><%=  @vabp.strftime("%d-%m") %></td>
                         <%  else %>
                         <td  ></td>
                          <%  end %>


         <%  @an=activity.nomenclatura.length %>

        <td ><%= activity.nomenclatura[0,@an] %></td>

        <% @vobac=" " %>
        <% if activity.expediente>0 then %>
       <% Item.where(exped:activity.expediente).each do |nobac| %>
       <% @sobac=Formula.where(product_id:1,orden:nobac.obac).select('nombre as dd').first.dd %>
       <% @vobac=@vobac+ @sobac+"-" %>
       <% end %>
       <% end %>
       <td  ><%= @vobac %></td>






        <td colspan="3"><%= activity.descripcion.underscore.capitalize %>




</td>






        <% if activity.moneda>0 and activity.moneda then %>
      <td ><%= Formula.where(product_id:7,orden:activity.moneda).select('nombre as dd').first.dd %></td>
      <% else %>
      <td ><%= "s/d "   %></td>
      <% end %>
<% @vreff=Piece.where(phase_id:activity.id.to_s).where('adjudicado>0 and adjudicado is not null').sum(:referencial)%>

  <%  if @vreff>0 then %>
        <td  colspan="1"><%= number_with_delimiter(@vreff.to_i, delimiter: ",") %></td>
  <%  else %>

      <td colspan="1"><%= number_with_delimiter( Phase.where(id:activity.id.to_s).sum(:valor).to_i, delimiter: ",") %></td>
  <%  end %>
      <%   if @vopc==2 or  @vopc==3 then %>

          <% @vbpro=Piece.where(phase_id:activity.id.to_s).sum(:adjudicado)%>

        <% if @vbpro >0 then %>

        <td  colspan="1"><%= number_with_delimiter(@vbpro.to_i, delimiter: ",") %></td>

             <% else %>
        <td>  </td>
              <% end %>

          <% end %>

      </tr>
      <% if Piece.where(phase:activity.id.to_s).count>0 and  (@vopc<3 or @vopc==4)  then  %>




          <tr style="font-size:80%;"  class="last">
            <th colspan="2"> </th>
            <th colspan="3" class="detl" >Item </th>
            <th colspan="1" class="detl" >Estado</th>

            <% if   @vopc==2 then %>
            <th colspan="2"  class="detl" >Postor Ganador</th>

             <th colspan="1" class="detl"> </th>
            <% end %>
            <th  class="detl" >Monto</th>

             <th colspan="1"> </th>

         </tr>



          <% Piece.where(phase:activity.id.to_s).each do |pite| %>


       <tr style="font-size:70%;"  class="last" >




                <td colspan="2"></td>


               <td  colspan="3" ><%= pite.descripcion.capitalize %></td>
                 <% if pite.estado and pite.estado>0 then %>

                  <td colspan="1" ><%= Formula.where(product_id:17, orden:pite.estado).
                   select('nombre as dd').first.dd %></td>


             <% else %>


                <td colspan="1" > s/d </td>
            <% end %>

      <% if   @vopc==2 then %>

               <td colspan="3" ><%= pite.postor.capitalize %></td>

        <% end %>

        <% if   pite.estado==2  or pite.estado==4 then %>
        <td ><%= number_with_delimiter(pite.adjudicado.to_i, delimiter: ",") %></td>

          <% else %>

        <td ><%= number_with_delimiter(pite.referencial.to_i, delimiter: ",") %></td>


                 <td colspan="1"> </td>

          <% end %>

       </tr>



        <% end %>



      <% end %>












    <% end %>

  </tbody>
  </table>



    <% if @vopc==2  then  %>
    <%@srefs= 0 %>
    <%@sadjs=0 %>
    <%@srefd= 0 %>
    <%@sadjd=0 %>
  <% @activities.each do |activity2| %>
    <% if activity2.moneda==1  then  %>

    <%@srefs= @srefs+ Piece.where(phase:activity2.id).where('adjudicado>0 and adjudicado is not null').sum(:referencial) %>
    <%@sadjs= @sadjs+ Piece.where(phase:activity2.id).where('adjudicado>0 and adjudicado is not null').sum(:adjudicado) %>
    <% end %>
      <% if activity2.moneda==2  then  %>
      <%@srefd= @srefd+ Piece.where(phase:activity2.id).where('adjudicado>0 and adjudicado is not null').sum(:referencial) %>
      <%@sadjd= @sadjd+ Piece.where(phase:activity2.id).where('adjudicado>0 and adjudicado is not null').sum(:adjudicado) %>
     <% end %>
      <% end %>


      <table>
        <thead>
        <h4>RESUMEN DE AHORRO</h4>
        </thead>
        <tr>
          <th>MONEDA</th>
          <th>REFERENCIAL</th>
          <th>ADJUDICADO</th>
          <th>AHORRO</th>
        </tr>
        <tr>
          <td>Soles</td>
          <td><%= number_with_delimiter(@srefs.to_i, delimiter: ",") %></td>
          <td><%= number_with_delimiter(@sadjs.to_i, delimiter: ",") %></td>
          <td><%= number_with_delimiter((@srefs-@sadjs).to_i, delimiter: ",") %></td>
        </tr>
        <tr>
          <td>Dolares</td>
          <td><%= number_with_delimiter(@srefd.to_i, delimiter: ",") %></td>
          <td><%= number_with_delimiter(@sadjd.to_i, delimiter: ",") %> </td>
          <td> <%= number_with_delimiter((@srefd-@sadjd).to_i, delimiter: ",") %></td>
        </tr>
        <tr>
          <td colspan="4">Soles y dolares</td>

        </tr>
      </table>

      <% end %>









<br>
<% else %>
<br>
<br>
 <td> No hay procesos programados  </td>
 <br>
 <br>
<% end %>
