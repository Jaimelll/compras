<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3>Periodo:<%=   @vper %> </h3>
<h4><%= @titproc %> AL<%= Time.now.strftime("%d-%m-%Y")%></h4>

</head>
<% if @items.count>0 then %>





  <table >
    <tr  style="font-size:90%;">

       <th>N°</th>

       <th  colspan="2">Proceso</th>
       <th  >PAC-FUENTE</th>
       <th  colspan="3">Descripcion</th>
       <th   >Presupuestado</th>
<% if  @vactcanti==6.to_s then %>
       <th   >Adjudicado</th>
<%  else %>
       <th   >Referencial</th>
<% end%>

    </tr>
    <tbody>

    <%  @conta=0 %>

    <% @items.each do |variable| %>



        <tr style="font-size:80%;"  class="detl">

      <% @conta=@conta+1 %>


      <%  case current_admin_user.categoria %>
      <%    when 21,22,23 %>

        <%  @vpact=Formula.where(product_id:12,acti:2).select('orden')%>
      <% else %>
        <%  @vpact=Formula.where(product_id:12).where('acti=1 or acti=2').select('orden')%>
      <%   end %>

  <%  @vpact3=Formula.where(product_id:12,acti:3).select('orden')%>

        <td><%= @conta.to_s+".-" %></td>




        <td colspan="2"><%= variable.nomenclatura %></td>
        <% @vobac=" " %>

        <% if variable.expediente>0 then %>
        <% Item.where(exped:variable.expediente).each do |nobac| %>
        <% @spac=nobac.pac%>
        <% @sobac=Formula.where(product_id:1,orden:nobac.obac).select('nombre as dd').first.dd %>
        <% if nobac.fuente then %>
        <% @sfuente=Formula.where(product_id:8,orden:nobac.fuente).select('nombre as dd').first.dd %>
          <% else %>
          <%  @sfuente=" "%>
            <% end %>
        <% @vobac=@vobac+ @spac+"-"+@sobac+"-"+ @sfuente+"//"%>


        <% end %>
        <% end %>
        <td  ><%= @vobac %></td>





        <td colspan="3"><%= variable.descripcion.capitalize %>  </td>

        <% @presu=Piece.where(phase_id:variable.id.to_s).sum(:presupuestado).to_i%>
                <td ><h5  ALIGN=center><%= number_with_delimiter( @presu.to_i, delimiter: ",") %></h5></td>

        <% if  @vactcanti==6.to_s then %>
        <% @vbpro=Piece.where(phase_id:variable.id.to_s).sum(:adjudicado)*
        Formula.where(product_id:7,orden:variable.moneda)
              .select('cantidad as dd').first.dd/100%>

                  <td ><h5  ALIGN=center><%= number_with_delimiter(@vbpro.to_i, delimiter: ",") %></h5></td>
        <%  else %>

        <% @reff=Piece.where(phase_id:variable.id.to_s).sum(:referencial)*
        Formula.where(product_id:7,orden:variable.moneda)
              .select('cantidad as dd').first.dd/100%>

                  <td ><h5  ALIGN=center><%= number_with_delimiter(@reff.to_i, delimiter: ",") %></h5></td>
        <% end%>


        </tr>


          <% if @vdetalle.where(phase_id:variable.id).where(actividad: @vpact).count>0 and @vpaso1.to_i==0 then %>

            <% @vdetact= @vdetalle.where(phase_id:variable.id).where(actividad: @vpact)%>






            <% if @vdetalle.where(phase_id:variable.id).where(actividad: @vpact3).count>0 then %>
            <%  @vdetalle.where(phase_id:variable.id).where(actividad:@vpact3).each do |deta| %>
              <tr  style="font-size:80%;"  class="detl">
            <td ></td>


              <% if deta.actividad==300 then%>
              <% @vestado='PROCESO CULMINADO:-'+deta.pfecha.strftime("%d/%m/%y")+"-"+ deta.obs.capitalize%>
              <% else%>
            <% @vestado='ESTADO='+deta.pfecha.strftime("%d/%m/%y").to_s+"-"+ deta.obs.capitalize    %>
              <% end%>


           <td colspan="8"><%=@vestado %></td>


            </tr>


              <% end %>
              <% end %>













              <tr style="font-size:80%;"  class="last">
                <th ></th>

                <th >Fecha  </th>

                <th colspan="3">Actividad</th>
                <th colspan="3">Observacion</th>
                <th ></th>
             </tr>

            <tbody>


              <% @vdetact.each do |deta| %>


           <tr style="font-size:70%;"  class="last">



                    <td ></td>

                   <td><%= deta.pfecha.strftime("%d-%m") %></td>


                   <td colspan="2"><%=Formula.where(product_id:12,orden:deta.actividad).
                               select('descripcion as dd').first.dd.capitalize  %></td>
                   <td colspan="4"><%= deta.obs.capitalize %></td>
                   <td ></td>
           </tr>

            <% end %>

            <tbody>



  <% end %>






    <% end %>
    <br>
  </tbody>
  </table>

<% else %>
<br>
<br>
 <td> No hay procesos en esta etapa  </td>
 <br>
 <br>
<% end %>
</html>
