
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3><%=   @tit1 %> </h3>
</head>

  <% if @activities.length>0 then %>
<table>



    <tr>
      <th>N°</th>

       <th>Fecha</th>

       <th>Nomenclatura</th>
       <th>Descripcion</th>
       <th>Moneda</th>
       <th>Estimado</th>


      <th colspan="3"></th>
    </tr>


  <tbody>
    <%  @conta=0 %>
    <% @activities.each do |activity| %>
        <tr>
          <% @conta=@conta+1 %>






        <td><%= @conta.to_s+".-" %></td>

        <%  if activity.pfecha then %>
        <td ALIGN=center ><%= activity.pfecha.strftime("%d-%m") %></td>
        <%  else %>
        <td ALIGN=center >s/d</td>
         <%  end %>

         <%  @an=activity.nomenclatura.length %>

        <td><h5><%= activity.nomenclatura[0,@an] %></h5></td>





        <td><%= activity.descripcion.underscore.capitalize %></td>

          <% if activity.moneda>0 and activity.moneda then %>
        <td><%= Formula.where(product_id:7,orden:activity.moneda).select('nombre as dd').first.dd %></td>
        <% else %>
      <td><%= " s/d"   %></td>
        <% end %>


        <td ALIGN=right><%= number_with_delimiter(activity.valor.to_i, delimiter: ",") %></td>


      </td>
      </tr>

    <% end %>

  </tbody>

</table>


<br>
<% else %>
<br>
<br>
 <td> No hay procesos programados  </td>
 <br>
 <br>
<% end %>
