<p id="notice"><%= notice %></p>

<h1>Packages</h1>

<table>
  <thead>
    <tr>
      <th>Item</th>
      <th>Moneda</th>
      <th>Adjudicado</th>
      <th>Presupuestado</th>
      <th>Admin user</th>
      <th>Contract</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @packages.each do |package| %>
      <tr>
        <td><%= package.item %></td>
        <td><%= package.moneda %></td>
        <td><%= package.adjudicado %></td>
        <td><%= package.presupuestado %></td>
        <td><%= package.admin_user %></td>
        <td><%= package.contract %></td>
        <td><%= link_to 'Show', package %></td>
        <td><%= link_to 'Edit', edit_package_path(package) %></td>
        <td><%= link_to 'Destroy', package, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Package', new_package_path %>
