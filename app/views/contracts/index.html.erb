<p id="notice"><%= notice %></p>

<h1>Contracts</h1>

<table>
  <thead>
    <tr>
      <th>Numero</th>
      <th>Fecha</th>
      <th>Descripcion</th>
      <th>Obac</th>
      <th>Postor</th>
      <th>Proveedor</th>
      <th>Moneda</th>
      <th>Adjudicado</th>
      <th>Presupuestado</th>
      <th>Admin user</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @contracts.each do |contract| %>
      <tr>
        <td><%= contract.numero %></td>
        <td><%= contract.fecha %></td>
        <td><%= contract.descripcion %></td>
        <td><%= contract.obac %></td>
        <td><%= contract.postor %></td>
        <td><%= contract.proveedor %></td>
        <td><%= contract.moneda %></td>
        <td><%= contract.adjudicado %></td>
        <td><%= contract.presupuestado %></td>
        <td><%= contract.admin_user %></td>
        <td><%= link_to 'Show', contract %></td>
        <td><%= link_to 'Edit', edit_contract_path(contract) %></td>
        <td><%= link_to 'Destroy', contract, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Contract', new_contract_path %>
