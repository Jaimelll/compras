wb.add_worksheet(name: proce.nombre+nuitem1) do |sheet|


  sheet.add_row []



  case proce.orden
     when 1
       sheet.add_row %w(N PAC FECHA_PAC OBAC EXPED DESCRIPCION MERCADO MODALIDAD FUENTE FEC_ING ESTIMADO(Soles) SITUACION),
       style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu]


     when 2
         sheet.add_row %w(N PAC FECHA_PAC OBAC EXPED DESCRIPCION MERCADO MODALIDAD FUENTE FEC_ING ESTIMADO(Soles) SITUACION),
         style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu]


     when 3
       sheet.add_row %w(N PAC FECHA_PAC OBAC EXPED DESCRIPCION MERCADO MODALIDAD FUENTE FEC_ING ESTIMADO(Soles) SITUACION),
      style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu]


     when 4
       sheet.add_row %w(N PAC FECHA_PAC OBAC EXPED DESCRIPCION MERCADO MODALIDAD FUENTE FEC_ING PLAN_EPOM FEC_EPOM FEC_CONV_PLAN ESTIMADO(Soles) SITUACION),
       style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu,titu, titu, titu, titu]



       when 5
         sheet.add_row %w(N PAC FECHA_PAC OBAC EXPED DESCRIPCION MERCADO MODALIDAD FUENTE FEC_ING PLAN_EPOM FEC_EPOM FEC_CONV_PLAN ESTIMADO(Soles) SITUACION),
         style: [titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu, titu,titu, titu, titu]



