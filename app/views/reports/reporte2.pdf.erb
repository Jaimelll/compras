
<!DOCTYPE html>
<html>
<head>
<title></title>
<%= wicked_pdf_stylesheet_link_tag 'pdf' %>
<meta charset="utf-8">
<h3><%= @tit1 %>-<%=   @lista.titleize %></h3>
</head>

  <% if @items.count>0 then %>
<% Formula.where(product_id:1,numero:1).order('orden').each do |formula| %>

  <% if @items.where(obac:formula.orden).count>0 then %>


<table>




    <tr>
      <th>N°</th>
      <th>Pac</th>

      <th>Obac</th>

      <th>Descripcion</th>

      <th>Estimado</th>


      <th colspan="3"></th>
    </tr>


  <tbody>

    <%  @conta=0 %>

    <% @items.where(obac:formula.orden).each do |item| %>

        <tr>
          <% @conta=@conta+1 %>






        <td ALIGN=center><%= @conta.to_s+".-" %></td>
        <td ALIGN=left><%= item.pac %></td>



        <td ALIGN=center><%= Formula.where(product_id:1,orden:item.obac).select('nombre as dd').first.dd %></td>

        <td><%= item.descripcion.underscore.capitalize %></td>

        <td ALIGN=right><%= number_with_delimiter(item.certificado.to_i, delimiter: ",") %></td>


      </td>

    </tr>
   <% end %>
   </tr>


           <td colspan="2" ><h4><%="PAC = "%></h4></td>
                <td ><h4><%=@items.where(obac:formula.orden).count %></h4></td>
        <td ALIGN=right><h4><%=" Monto Total de "+formula.nombre.upcase+" =" %></h4> </td>
        <td ><h4><%= number_with_delimiter(@items.where(obac:formula.orden).sum(:certificado).to_i, delimiter: ",")   %></td>







  </tbody>

</table>
<% end %>
  <% end %>
<h3>PACs = <%=   @items.count %></h3>
<h3>Total(Soles) = <%=   number_with_delimiter(@items.sum(:certificado).to_i, delimiter: ",") %></h3>

<br>

<% else %>
<br>
<br>
 <td> No hay PACs Ingresados  </td>
 <br>
 <br>
<% end %>
